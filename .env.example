# Copy to .env.local for local dev. Never commit real secrets.

# ---- Public (safe to expose to the browser) ----
# Used by the Angular app to talk to Supabase Auth only.
NG_APP_SUPABASE_URL=https://your-project-ref.supabase.co
NG_APP_SUPABASE_ANON_KEY=your-anon-key
NG_APP_API_BASE_URL=http://localhost:3000

# ---- Server-only (Vercel env, never shipped to client) ----
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5-mini

# Optional: monthly per-user AI quotas (defaults applied if unset)
AI_QUOTA_EXPIRATION_PER_MONTH=1000
AI_QUOTA_RECEIPT_PER_MONTH=100

# CORS - comma-separated list of allowed origins for /api/*
API_ALLOWED_ORIGINS=http://localhost:4200,https://your-vercel-domain.vercel.app

# ---- Web Push (Phase B) ----
# Generate once: npx web-push generate-vapid-keys
NG_APP_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
CRON_SECRET=generate-a-long-random-string

# ---- Optional: error tracking (Phase 8) ----
# Frontend Sentry DSN; leave blank to disable client-side error reporting.
NG_APP_SENTRY_DSN=
# Deployment environment label - usually "production" or "staging".
NG_APP_ENVIRONMENT_NAME=development

# ---- Optional: cost guardrails ----
# Soft monthly $ ceiling for OpenAI; surfaced via dashboard alerts.
OPENAI_MONTHLY_BUDGET_USD=50
